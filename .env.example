# Copy to .env and fill in. .env is gitignored — never commit real keys.

# News for the "긍정 뉴스 증가" filter, picked per market:
#   US -> NewsAPI (https://newsapi.org), English.
#   KR -> Naver search (https://developers.naver.com), Korean. Register an app,
#         pick the 검색 API; free quota 25,000/day.
# A market with no key scores neutral (the filter won't exclude it).
NEWSAPI_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# DART OpenAPI (https://opendart.fss.or.kr) — enables KR fundamentals in the
# "펀더멘털" filter. Without this, KR tickers score neutral (50, never excluded);
# US fundamentals work without any key (yfinance).
DART_API_KEY=

# Telegram alerts (optional). Without these, alerts print to stdout.
# Create a bot via @BotFather; get chat_id from getUpdates. See docs/.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
